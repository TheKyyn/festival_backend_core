# --- Application ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL (utilisé par docker-compose) ---
POSTGRES_USER=festival
POSTGRES_PASSWORD=festival
POSTGRES_DB=festival

# URL de connexion utilisée par Prisma (étape Infrastructure)
DATABASE_URL="postgresql://festival:festival@localhost:5432/festival?schema=public"

# --- Authentification (JWT + bcrypt) ---
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=10
